{
  "files": {
    "includes": ["src/**/*.ts", "src/**/*.tsx"]
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "javascript": {
    "formatter": {
      "lineWidth": 80,
      "indentStyle": "space",
      "quoteStyle": "single"
    }
  },
  "json": {
    "formatter": {
      "lineWidth": 80,
      "indentStyle": "space"
    }
  }
}
